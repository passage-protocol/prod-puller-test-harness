{
  "name": "@passage-protocol/e2e-helpers",
  "version": "1.0.2",
  "description": "Shared Playwright E2E test helpers for prod-puller services",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./fixture": {
      "import": "./dist/fixture.js",
      "types": "./dist/fixture.d.ts"
    },
    "./health": {
      "import": "./dist/health.js",
      "types": "./dist/health.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/passage-protocol/prod-puller-test-harness.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.50.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3"
  }
}
